pipeline {
    agent any

    environment {
        PATH = "/usr/bin:/usr/local/bin:${env.PATH}"
        NODE_OPTIONS = "--max-old-space-size=4096"
        SONAR_SCANNER_HOME = "/opt/sonar-scanner"
        SONAR_HOST_URL = "http://100.105.57.78:9000"
        SONAR_AUTH_TOKEN = "${env.SONAR_TOKEN}"
        SONAR_PROJECT_KEY = "${env.SONAR_PROJECT_KEY}"
        TRIVY_CACHE_DIR = "/var/lib/jenkins/.cache/trivy"
        BUILD_NUMBER = "${env.BUILD_NUMBER}"
        DOCKER_REGISTRY = "http://100.105.57.78:8080/employee-recommendation"
        DOCKER_IMAGE_TAG = "backend-${BUILD_NUMBER}"
        JENKINS_URL = "http://100.105.57.78:8080"
        JENKINS_TOKEN = "${env.JENKINS_TOKEN}"
    }

    options {
        buildDiscarder(logs: true, keepUnstable: false)
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {
        stage('📥 Checkout') {
            steps {
                checkout scm
                echo '✅ Code checkout completed - Commit: ${env.GIT_COMMIT}'
            }
        }

        stage('🔍 SonarQube Analysis') {
            steps {
                dir('backend') {
                    sh '''
                        echo '🔍 Verifying coverage file exists...'
                        if [ -f "coverage/lcov.info" ]; then
                            echo '✅ Coverage file found'
                            echo '📊 Coverage summary:'
                            cat coverage/lcov.info | grep -E "LF:|LH:" | tail -2
                        else
                            echo '❌ Coverage file not found'
                            echo '📁 Available files:'
                            ls -la coverage/ || echo 'No coverage directory'
                            exit 1
                        fi
                        
                        echo '🔍 Starting SonarQube analysis...'
                        /opt/sonar-scanner/bin/sonar-scanner \\
                            -Dsonar.projectKey=${SONAR_PROJECT_KEY} \\
                            -Dsonar.projectName=Employee Recommendation Backend \\
                            -Dsonar.sources=src \\
                            -Dsonar.tests=test \\
                            -Dsonar.test.inclusions=**/*.spec.ts,**/*.test.ts \\
                            -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \\
                            -Dsonar.typescript.lcov.reportPaths=coverage/lcov.info \\
                            -Dsonar.host.url=${SONAR_HOST_URL} \\
                            -Dsonar.login=${SONAR_AUTH_TOKEN}
                    '''
                }
            }
            post {
                always {
                    sh '''
                        echo '🔍 SonarQube Results:'
                        echo '📊 Quality Gate: ${env.SONAR_QUBE_STATUS:-PASSED}'
                        echo '🐛 Bugs: ${env.SONAR_BUGS:-0}'
                        echo '🔥 Vulnerabilities: ${env.SONAR_VULNERABILITIES:-0}'
                        echo '📈 Coverage: ${env.SONAR_COVERAGE:-0}%'
                        echo '🔧 Maintainability: ${env.SONAR_MAINTAINABILITY:-A}'
                        echo '🔒 Reliability: ${env.SONAR_RELIABILITY:-A}'
                        echo '🔒 Security: ${env.SONAR_SECURITY:-A}'
                        echo '📋 Sonar Report: sonar-backend-report.json'
                    '''
                }
            }
        }

        stage('🧪 Security Scan') {
            steps {
                dir('backend') {
                    sh '''
                        echo '🧪 Starting security scan...'
                        /opt/trivy-scanner/bin/trivy \\
                            --cache-dir ${TRIVY_CACHE_DIR} \\
                            --exit-code 0 \\
                            --severity HIGH,CRITICAL \\
                            --format json \\
                            --output trivy-backend-report.json
                    '''
                }
            }
            post {
                always {
                    sh '''
                        HIGH_VULNS=$(cat trivy-backend-report.json | jq '.Results[0].Vulnerabilities | map(select(.Severity == "HIGH") | length')
                        CRITICAL_VULNS=$(cat trivy-backend-report.json | jq '.Results[0].Vulnerabilities | map(select(.Severity == "CRITICAL") | length')
                        
                        echo '🧪 Security Scan Results:'
                        echo '📊 Total Vulnerabilities: $(cat trivy-backend-report.json | jq '.Results[0].Vulnerabilities | length)'
                        echo '🚨 High/Critical: $((HIGH_VULNS + CRITICAL_VULNS))'
                        echo '📋 Security Report: trivy-backend-report.json'
                        
                        if [ "$((HIGH_VULNS + CRITICAL_VULNS))" -gt 0 ]; then
                            echo '❌ SECURITY GATE FAILED: High/Critical vulnerabilities found!'
                            exit 1
                        else
                            echo '✅ SECURITY GATE PASSED: No high/critical vulnerabilities'
                        fi
                    '''
                }
            }
        }

        stage('📦 Install Dependencies') {
            steps {
                dir('backend') {
                    sh '''
                        export HOME=/tmp
                        /usr/bin/npm install
                    '''
                }
            }
        }

        stage('🧪 Tests') {
            steps {
                dir('backend') {
                    sh '''
                        export HOME=/tmp
                        /usr/bin/npm test --coverage --watchAll=false
                    '''
                }
            }
            post {
                always {
                    sh '''
                        echo '🧪 Test Results:'
                        echo '📊 Test Results: $(cat coverage/lcov.info | grep -o "lines.*:" | tail -1)'
                        echo '📈 Coverage Report: coverage/lcov.info'
                    '''
                }
            }
        }

        stage('🐳 Docker Build') {
            steps {
                dir('backend') {
                    sh '''
                        echo '🐳 Building Docker image...'
                        docker build -t ${DOCKER_REGISTRY}/${DOCKER_IMAGE_TAG}:${BUILD_NUMBER} .
                        echo '🐳 Docker image built: ${DOCKER_REGISTRY}/${DOCKER_IMAGE_TAG}:${BUILD_NUMBER}'
                    '''
                }
            }
        }

        stage('🚀 Deploy') {
            when {
                branch 'main'
            }
            steps {
                dir('backend') {
                    sh '''
                        echo '🚀 Deploying to production...'
                        # Add your deployment commands here
                        # Example: docker push ${DOCKER_REGISTRY}/${DOCKER_IMAGE_TAG}:${BUILD_NUMBER}
                        # Example: kubectl apply -f deployment.yaml
                        echo '✅ Deployment completed'
                    '''
                }
            }
        }
    }

    post {
        always {
            sh '''
                echo '📋 PIPELINE SUMMARY:'
                echo '✅ Build Status: Success'
                echo '📊 Quality Gate: ${env.SONAR_QUBE_STATUS:-PASSED}'
                echo '🔥 Vulnerabilities: ${env.SONAR_VULNERABILITIES:-0}'
                echo '🔒 Security Status: ${env.SECURITY_STATUS:-PASSED}'
                echo '🐳 Docker Image: ${DOCKER_REGISTRY}/${DOCKER_IMAGE_TAG}:${BUILD_NUMBER}'
                echo '🚀 Deploy Status: ${env.DEPLOY_STATUS:-SUCCESS}'
            '''
        }
    }
}
