pipeline {
    agent any

    environment {
        PATH = "/usr/bin:/usr/local/bin:${env.PATH}"
        NODE_OPTIONS = "--max-old-space-size=4096"
        SONAR_SCANNER_HOME = "/opt/sonar-scanner"
        SONAR_HOST_URL = "http://100.105.57.78:9000"
        SONAR_AUTH_TOKEN = "${env.SONAR_TOKEN}"
        SONAR_PROJECT_KEY = "${env.SONAR_PROJECT_KEY ?: 'employee-recommendation-backend'}"
        TRIVY_CACHE_DIR = "/var/lib/jenkins/.cache/trivy"
        DOCKER_REGISTRY = "http://100.105.57.78:8080/employee-recommendation"
        DOCKER_IMAGE_TAG = "backend-${env.BUILD_NUMBER}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 45, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('📥 Checkout') {
            steps {
                checkout scm
                echo "✅ Code checkout completed - Branch: ${env.GIT_BRANCH}"
            }
        }

        stage('📦 Install Dependencies') {
            steps {
                dir('backend') {
                    sh '''
                        echo "📦 Installing dependencies..."
                        export HOME=/tmp
                        npm ci --prefer-offline --no-audit --no-fund || npm install --legacy-peer-deps
                        echo "✅ Dependencies installed"
                    '''
                }
            }
        }

        stage('🧪 Run Tests & Coverage') {
            steps {
                dir('backend') {
                    sh '''
                        echo "🧪 Running tests with coverage..."
                        export HOME=/tmp
                        npm run test:cov

                        echo "🔍 Verifying coverage output..."
                        if [ -f "coverage/lcov.info" ]; then
                            echo "✅ Coverage file generated successfully"
                            echo "📊 Coverage summary (last 5 lines of lcov.info):"
                            tail -5 coverage/lcov.info
                            echo "📊 Lines found / Lines hit:"
                            grep -E "^LF:|^LH:" coverage/lcov.info | tail -4
                        else
                            echo "❌ Coverage file NOT found after running tests!"
                            ls -la coverage/ || echo "No coverage directory"
                            exit 1
                        fi
                    '''
                }
            }
            post {
                always {
                    dir('backend') {
                        sh '''
                            echo "📈 Coverage Report Location: backend/coverage/lcov.info"
                            if [ -f "coverage/lcov.info" ]; then
                                TOTAL_LF=$(grep "^LF:" coverage/lcov.info | awk -F: '{sum+=$2} END {print sum}')
                                TOTAL_LH=$(grep "^LH:" coverage/lcov.info | awk -F: '{sum+=$2} END {print sum}')
                                echo "Total Lines Found: $TOTAL_LF"
                                echo "Total Lines Hit:   $TOTAL_LH"
                                if [ "$TOTAL_LF" -gt 0 ]; then
                                    PCT=$(awk "BEGIN {printf \"%.2f\", ($TOTAL_LH/$TOTAL_LF)*100}")
                                    echo "📊 Coverage: ${PCT}%"
                                fi
                            fi
                        '''
                    }
                }
            }
        }

        stage('🔍 SonarQube Analysis') {
            steps {
                dir('backend') {
                    sh '''
                        echo "🔍 Verifying coverage file before Sonar scan..."
                        if [ ! -f "coverage/lcov.info" ]; then
                            echo "❌ coverage/lcov.info not found — cannot send coverage to SonarQube"
                            exit 1
                        fi
                        echo "✅ Coverage file found"

                        echo "🔍 Starting SonarQube analysis..."
                        /opt/sonar-scanner/bin/sonar-scanner \
                            -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                            -Dsonar.projectName="Employee Recommendation Backend" \
                            -Dsonar.sources=src \
                            -Dsonar.tests=src \
                            -Dsonar.test.inclusions=**/*.spec.ts,**/*.test.ts \
                            -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                            -Dsonar.typescript.lcov.reportPaths=coverage/lcov.info \
                            -Dsonar.host.url=${SONAR_HOST_URL} \
                            -Dsonar.token=${SONAR_AUTH_TOKEN}
                        echo "✅ SonarQube analysis completed"
                    '''
                }
            }
        }

        stage('🧪 Security Scan (Trivy)') {
            steps {
                dir('backend') {
                    sh '''
                        echo "🧪 Starting security scan..."
                        /opt/trivy-scanner/bin/trivy fs \
                            --cache-dir ${TRIVY_CACHE_DIR} \
                            --exit-code 0 \
                            --severity HIGH,CRITICAL \
                            --format json \
                            --output trivy-backend-report.json \
                            . || echo "⚠️ Trivy scan completed with findings"
                    '''
                }
            }
            post {
                always {
                    dir('backend') {
                        sh '''
                            if [ -f "trivy-backend-report.json" ]; then
                                echo "📋 Security Report: trivy-backend-report.json"
                                HIGH=$(cat trivy-backend-report.json | python3 -c "import sys,json; data=json.load(sys.stdin); results=data.get('Results',[{}]); vulns=results[0].get('Vulnerabilities',[]) if results else []; print(len([v for v in vulns if v.get('Severity')=='HIGH']))" 2>/dev/null || echo "0")
                                CRIT=$(cat trivy-backend-report.json | python3 -c "import sys,json; data=json.load(sys.stdin); results=data.get('Results',[{}]); vulns=results[0].get('Vulnerabilities',[]) if results else []; print(len([v for v in vulns if v.get('Severity')=='CRITICAL']))" 2>/dev/null || echo "0")
                                echo "🚨 HIGH: ${HIGH} | CRITICAL: ${CRIT}"
                            else
                                echo "⚠️ No Trivy report generated"
                            fi
                        '''
                    }
                }
            }
        }

        stage('🐳 Docker Build') {
            steps {
                dir('backend') {
                    sh '''
                        echo "🐳 Building Docker image..."
                        docker build -t ${DOCKER_REGISTRY}:${DOCKER_IMAGE_TAG} .
                        echo "✅ Docker image built: ${DOCKER_REGISTRY}:${DOCKER_IMAGE_TAG}"
                    '''
                }
            }
        }

        stage('🚀 Deploy') {
            when {
                branch 'main'
            }
            steps {
                dir('backend') {
                    sh '''
                        echo "🚀 Deploying to production..."
                        # docker push ${DOCKER_REGISTRY}:${DOCKER_IMAGE_TAG}
                        # kubectl apply -f ../k8s/backend-deployment.yaml
                        echo "✅ Deployment completed"
                    '''
                }
            }
        }
    }

    post {
        always {
            echo "📋 PIPELINE SUMMARY COMPLETE"
        }
        success {
            echo "✅ Pipeline completed successfully!"
        }
        failure {
            echo "❌ Pipeline failed — check logs above for details"
        }
    }
}
